{
  "$schema": "https://raw.githubusercontent.com/c3lang/c3c/refs/heads/master/resources/project_schema.json",
  "langrev": "1",
  "warnings": [
    "no-unused"
  ],
  "dependency-search-paths": [
    "lib"
  ],
  "dependencies": [
    "c3io"
  ],
  "authors": [
    "Shishant Biswas <shishantbiswas@gmail.com>"
  ],
  "version": "0.1.1",
  "sources": [
    "src/**"
  ],
  "test-sources": [
    "test/**"
  ],
  "output": "build",
  "targets": {
    "web": {
      "sources": [
        "src/examples/demo.c3"
      ],
      "type": "executable"
    },
    "ceb": {
      "type": "static-lib"
    }
  },
  "cpu": "generic",
  "opt": "O0"
}